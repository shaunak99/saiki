# Supabase Configuration
# Copy this file to .env and fill in your actual values

# Your Supabase project URL
# Find this in: Project Settings > API > Project URL
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co

# Your Supabase API key
# For development: Use the "anon" key from Project Settings > API
# For production: Use the "service_role" key (keep this secret!)
SUPABASE_KEY=your-anon-or-service-key-here

# Storage bucket name (create this in Storage > Buckets)
# Default bucket name for this example
SUPABASE_BUCKET=dexto-blobs
